{
	"name": "tui",
	"version": "0.0.0",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"dev": "bun --watch source/cli.tsx",
		"start": "bun source/cli.tsx",
		"build": "bun build source/cli.tsx --outdir dist --target bun",
		"test": "prettier --check . && xo && bun test"
	},
	"files": ["dist"],
	"dependencies": {
		"@spiderq/core": "workspace:*",
		"ink": "^4.1.0",
		"ink-scroll-view": "^0.3.6",
		"ink-text-input": "^6.0.0",
		"meow": "^11.0.0",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
