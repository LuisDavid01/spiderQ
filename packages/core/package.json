{
  "name": "@spiderq/core",
  "version": "0.0.1",
  "description": "Core package for SpiderQ",
  "main": "./src/index.ts",
  "scripts": {
	"db:clean": "node -e \"require('fs').rmSync('./src/db/main.db', { force: true });\" && drizzle-kit push && bun src/db/seed.ts",
	"db:seed": "bun src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "exports":{
	  ".": "./src/index.ts",
	  "./types": "./types.ts"
  },
  "type": "module",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "whatwg-url": "13.0.0"
  },
  "devDependencies": {
	"@types/bun": "latest",  
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@toon-format/toon": "^1.2.0",
    "autoevals": "^0.0.101",
    "better-sqlite3": "^12.6.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "figlet": "^1.9.3",
    "got": "^14.4.4",
    "gradient-string": "^3.0.0",
    "linkedom": "^0.18.12",
    "log-update": "^7.0.1",
    "openai": "^6.18.0",
    "ora": "^8.2.0",
    "terminal-image": "^3.0.0",
    "tsx": "^4.19.2",
    "uuid": "^11.0.2",
    "zod": "^3.23.8"
  }
}
